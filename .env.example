# Copy to .env and fill in. NEVER commit the .env file.

# --- Kalshi Exchange (Phase 3 step 5a+, PRIMARY VENUE for US operator) ---
# Register at https://kalshi.com/ (US-legal, free account)
# Generate an API keypair on the Kalshi dashboard:
#   Dashboard -> Settings -> API Keys -> Create API Key
# Save the private PEM to data/kalshi_private_key.pem (gitignored, claudeignored)
# Paste the key ID (UUID) below.
KALSHI_API_KEY_ID=

# --- Football-Data.org (Phase 0) ---
# Free tier: register at https://www.football-data.org/client/register
FOOTBALL_DATA_ORG_KEY=

# --- The Odds API (Phase 2+, optional) ---
# Free tier 500 req/month: https://the-odds-api.com/
THE_ODDS_API_KEY=

# --- Gemini API (free fallback for parsing tasks when Ollama too slow) ---
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Runtime gates ---
LIVE_TRADING=false
LOG_LEVEL=INFO
DUCKDB_PATH=./data/footy_ev.duckdb

# --- LLM routing ---
# Which LLM to prefer for extraction tasks: ollama | gemini
LLM_EXTRACTOR=ollama
OLLAMA_MODEL=llama3.1:8b
GEMINI_MODEL=gemini-2.5-flash

# --- GitHub (used by `.\make.ps1 push` to authenticate `git push`) ---
# Personal access token (classic) with `repo` scope, or fine-grained token
# with Contents: Read and write on the target repo.
# Generate at https://github.com/settings/tokens — keep it OUT of git config.
GITHUB_TOKEN=
